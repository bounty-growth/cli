{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["es2023", "dom"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node", "vitest/globals"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "tsup.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
