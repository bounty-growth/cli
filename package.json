{
  "name": "bounty-cli",
  "version": "0.1.6",
  "description": "Bounty marketing operations CLI for authenticated agent workflows.",
  "private": false,
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "main": "./dist/index.cjs",
  "exports": "./dist/index.cjs",
  "bin": {
    "bounty-cli": "dist/index.cjs"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "bounty",
    "marketing",
    "analytics",
    "cli",
    "agent"
  ],
  "homepage": "https://www.bountygrowth.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounty-growth/cli.git"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts && yarn bundle-check",
    "bundle-check": "node scripts/check-bounty-cli-bundle.mjs",
    "bounty": "tsx src/index.ts",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.4.2",
    "@supabase/supabase-js": "^2.86.0",
    "@types/node": "^20",
    "commander": "^14.0.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0",
    "zod": "^4.2.0"
  }
}
